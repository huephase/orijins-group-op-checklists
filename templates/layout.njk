<!doctype html><html lang="{{ config.app.defaultLocale if config else 'en' }}"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"><meta name="theme-color" content="#17130f"><title>{{ title }} · {{ appName }}</title><link rel="manifest" href="/assets/manifest.webmanifest"><link rel="stylesheet" href="/assets/app.css"><script type="module" src="/assets/app.js"></script></head>
<body style="--primary:{{ request.tenant.config.palette.primary }};--secondary:{{ request.tenant.config.palette.secondary }};--accent:{{ request.tenant.config.palette.accent }};--background:{{ request.tenant.config.palette.background }};--text:{{ request.tenant.config.palette.text }}">
<header class="main-header"><a href="/" class="brand">{{ appName }}</a>{% if user %}<form action="/logout" method="post"><button class="link-button">Sign out</button></form>{% endif %}</header>
{% if request.tenant %}<nav class="tenant-header" aria-label="Tenant navigation"><img src="{{ request.tenant.config.logoPath }}" alt="" width="38" height="38"><strong>{{ request.tenant.config.displayName }}</strong>{% if user %}<a href="/forms">Forms</a>{% endif %}</nav>{% endif %}
<main class="container">{% block content %}{% endblock %}</main><div id="sync-status" class="sync-status" role="status" aria-live="polite" hidden></div></body></html>
