{% extends "layout.njk" %}{% from "forms/field.njk" import render %}{% block content %}<a href="/forms">← Forms</a><h1>{{ form.title }}</h1><p class="lead">{{ form.description }}</p><form id="operations-form" class="stack" data-form-key="{{ form.key }}" data-version="{{ form.version }}" data-requires-gps="{{ form.requiresGps }}"><div class="gps" data-gps><strong>Location</strong><span>Waiting for permission…</span><input name="gpsUnavailableReason" placeholder="Reason location is unavailable" hidden></div>{% for field in form.fields %}{{ render(field) }}{% endfor %}<div class="form-actions"><button type="button" class="secondary" data-save-draft>Save draft</button><button type="submit">Submit checklist</button></div></form>{% endblock %}
